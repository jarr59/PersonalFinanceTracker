@page "/transactions"
@using FinanceTracker.Web.Components.Transactions
@using FinanceTracker.Web.Components.Transactions.ViewModels
@using FinanceTracker.Web.Services.Categories
@using FinanceTracker.Web.Services.Transactions
@using FinanceTracker.Web.States.Transactions
@using FinanceTracker.Web.States.Categories
@using FinanceTracker.Web.States.Categories.DTOs
@using FinanceTracker.Web.States.Accounts
@inject ICategoryServices CategoryService
@inject ITransactionService TransactionService
@inject TransactionState TransactionState
@inject CategoryState CategoryState
@inject AccountState AccountState
@inherits StateAwareComponent
@rendermode InteractiveServer

<Sidebar />

<div class="main-content">
    <TopHeader />

    <div class="page-header">
        <h1 class="page-title">Transacciones</h1>
        <button class="btn-primary" @onclick="OpenAddModal" disabled="@TransactionState.IsSaving">
            <span class="material-icons">add</span> Nueva Transacción
        </button>
    </div>

    <div class="transactions-stats">
        <div class="stat-card stat-income">
            <div class="stat-icon">
                <span class="material-icons" style="font-size: 32px;">trending_up</span>
            </div>
            <div class="stat-info">
                <div class="stat-label">Ingresos Totales</div>
                <div class="stat-value">$@TransactionState.GetTotalIncome().ToString("N2")</div>
            </div>
        </div>
        <div class="stat-card stat-expense">
            <div class="stat-icon">
                <span class="material-icons" style="font-size: 32px;">trending_down</span>
            </div>
            <div class="stat-info">
                <div class="stat-label">Gastos Totales</div>
                <div class="stat-value">$@TransactionState.GetTotalExpenses().ToString("N2")</div>
            </div>
        </div>
        <div class="stat-card stat-balance">
            <div class="stat-icon">
                <span class="material-icons" style="font-size: 32px;">account_balance_wallet</span>
            </div>
            <div class="stat-info">
                <div class="stat-label">Balance</div>
                <div class="stat-value">$@((TransactionState.GetTotalIncome() - TransactionState.GetTotalExpenses()).ToString("N2"))</div>
            </div>
        </div>
    </div>

    @if (TransactionState.IsLoading)
    {
        <div class="loading-spinner">
            <span class="material-icons spinning">refresh</span> Cargando transacciones...
        </div>
    }
    else
    {
        <div class="transactions-list">
            @foreach (TransactionModel transaction in TransactionState.Transactions.OrderByDescending(t => t.Date))
            {
                <div class="transaction-item @(transaction.Amount >= 0 ? "income" : "expense")" @key="transaction.Id">
                    <div class="transaction-category">
                        <div class="category-icon" style="background: @(transaction.CategoryColor)22; color: @transaction.CategoryColor;">
                            <span class="material-icons">@transaction.CategoryIcon</span>
                        </div>
                        <div class="transaction-info">
                            <div class="transaction-description">@transaction.Description</div>
                            <div class="transaction-meta">
                                <span class="transaction-category-name">@transaction.CategoryName</span>
                                <span class="transaction-separator">•</span>
                                <span class="transaction-account">@transaction.AccountName</span>
                            </div>
                        </div>
                    </div>
                    <div class="transaction-right">
                        <div class="transaction-amount @(transaction.Amount >= 0 ? "positive" : "negative")">
                            @(transaction.Amount >= 0 ? "+" : "-")$@Math.Abs(transaction.Amount).ToString("N2")
                        </div>
                        <div class="transaction-date">@transaction.Date.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="transaction-actions">
                        <button class="btn-icon" @onclick="() => OpenEditModal(transaction)" disabled="@TransactionState.IsSaving">
                            <span class="material-icons">edit</span>
                        </button>
                        <button class="btn-icon btn-danger" @onclick="() => DeleteTransaction(transaction.Id)" disabled="@TransactionState.IsDeleting">
                            @if (TransactionState.IsDeleting)
                            {
                                <span class="material-icons spinning">refresh</span>
                            }
                            else
                            {
                                <span class="material-icons">delete</span>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <TransactionModal IsVisible="@showModal"
                      IsEditing="@isEditing"
                      IsSaving="@TransactionState.IsSaving"
                      Model="@currentTransaction"
                      Categories="@CategoryState.Categories"
                      Accounts="@AccountState.Accounts"
                      OnClose="@CloseModal"
                      OnSave="@SaveTransaction" />
</div>

@code {
    private bool showModal = false;
    private bool isEditing = false;
    private TransactionModalVM currentTransaction = new();

    protected override async Task OnInitializedAsync()
    {
        await Subscribe(TransactionState);
        await Subscribe(CategoryState);
        await Subscribe(AccountState);
        await CategoryService.LoadAllCategories();
        await TransactionService.LoadAllTransactionsAsync();
        await base.OnInitializedAsync();
    }

    private void OpenAddModal()
    {
        isEditing = false;
        currentTransaction = new TransactionModalVM
        {
            Id = Guid.NewGuid(),
            Date = DateTime.Now
        };
        showModal = true;
    }

    private void OpenEditModal(TransactionModel transaction)
    {
        isEditing = true;
        currentTransaction = new TransactionModalVM
        {
            Id = transaction.Id,
            Description = transaction.Description,
            Amount = transaction.Amount,
            Date = transaction.Date,
            CategoryId = transaction.CategoryId,
            AccountId = transaction.AccountId
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentTransaction = new TransactionModalVM();
    }

    private async Task SaveTransaction(TransactionModalVM model)
    {
        if (string.IsNullOrWhiteSpace(model.Description))
        {
            return;
        }

        if (model.CategoryId == Guid.Empty || model.AccountId == Guid.Empty)
        {
            return;
        }

        if (isEditing && model.Id.HasValue)
        {
            await TransactionService.UpdateTransactionAsync(
                model.Id.Value,
                model.Description,
                model.Amount,
                model.Date,
                model.CategoryId,
                model.AccountId);
        }
        else
        {
            await TransactionService.CreateTransactionAsync(
                model.Description,
                model.Amount,
                model.Date,
                model.CategoryId,
                model.AccountId);
        }

        CloseModal();
    }

    private async Task DeleteTransaction(Guid id)
    {
        await TransactionService.DeleteTransactionAsync(id);
    }
}
